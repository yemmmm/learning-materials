# ===========================================================================
# RAGFlow 性能压测配置
# ===========================================================================
# 复制此文件并根据你的环境修改，然后用以下命令 source:
#   source config.env
#
# 所有变量都可通过环境变量或 CLI 参数指定，CLI 优先级更高。
# ===========================================================================

# ---- 目标服务地址 ----
# RAGFlow 的 LB 入口地址（Nginx / HAProxy / Traefik 等）
export RAGFLOW_URL="http://10.0.0.100:18080"

# ---- 认证信息 ----
# 邮箱登录（推荐）或直接使用 API Token
export RAGFLOW_EMAIL="admin@example.com"
export RAGFLOW_PASSWORD="your_password_here"
# export RAGFLOW_API_KEY="ragflow-xxxxxxxxxxxx"  # 可选，优先级高于邮箱

# ---- 知识库 ID ----
# 需要预先在 RAGFlow 中创建知识库并上传文档
# 用逗号分隔，建议至少 3 个以模拟真实负载
export RAGFLOW_KB_IDS="kb_id_1,kb_id_2,kb_id_3"

# ---- 并发梯度 ----
# 建议先从较小的梯度开始，确认系统稳定后再扩大
CONCURRENCIES="10,30,50,100,200"

# ---- 测试时长 ----
DURATION=60       # 每轮正式压测时长（秒）
WARMUP=15         # 每轮预热时长（秒）

# ---- 输出目录 ----
OUTPUT_DIR="./results"

# ---- 高级参数 ----
MAX_CONNECTIONS=200      # httpx 连接池上限
TOTAL_TIMEOUT=120        # 单请求总超时（秒），需大于 Embedding API 最长延迟
CONNECT_TIMEOUT=10       # TCP 连接超时（秒）

# ===========================================================================
# 监控节点配置（可选）
# ===========================================================================
# 在每台 RAGFlow 服务器上手动运行 monitor.py，或通过 SSH 自动启动：
#
# MONITOR_HOSTS 格式: user@host:port:label
# 示例:
#   export MONITOR_HOSTS="root@10.0.0.11:22:web1 root@10.0.0.12:22:web2 root@10.0.0.10:22:infra"
#
# 留空表示手动启动 monitor.py
# ===========================================================================

export MONITOR_HOSTS=""
