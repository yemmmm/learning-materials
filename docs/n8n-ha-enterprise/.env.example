# =============================================================================
# n8n Enterprise HA - 环境变量
# =============================================================================
# 使用方法：
#   1. cp .env.example .env
#   2. 修改所有 CHANGE_ME 占位符
#   3. 主服务器和副服务器共用相同的 N8N_ENCRYPTION_KEY 和 RUNNERS_AUTH_TOKEN
#   4. 副服务器的 QUEUE_BULL_REDIS_HOST 指向主服务器域名
# =============================================================================

# --- n8n 版本 ----------------------------------------------------------------
# 固定版本，生产环境不要使用 stable/latest 漂移标签
N8N_VERSION=2.26.8

# --- 外部 PostgreSQL 数据库 ---------------------------------------------------
# 由外部管理，请填写实际连接信息
DB_POSTGRESDB_HOST=CHANGE_ME_PG_HOST
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=CHANGE_ME_PG_DATABASE
DB_POSTGRESDB_USER=CHANGE_ME_PG_USER
DB_POSTGRESDB_PASSWORD=CHANGE_ME_PG_PASSWORD
DB_POSTGRESDB_SCHEMA=public

# --- Redis (BullMQ 队列 + Leader 选举) ---------------------------------------
# 主服务器 (11vm): redis（容器内 DNS）
# 副服务器 (10vm): li19dksfai11vm.bmwgroup.net（通过主机网络访问主服务器 Redis）
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
QUEUE_BULL_REDIS_DB=0

# Redis 对外暴露端口（仅主服务器需要，供副服务器连接）
REDIS_BIND_PORT=6379

# --- MinIO / S3 binary data ---------------------------------------------------
# Queue Mode 下建议使用 S3-compatible external storage 保存二进制数据
MINIO_ROOT_USER=n8nminio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
MINIO_API_BIND_PORT=9000
MINIO_CONSOLE_PORT=9001

N8N_AVAILABLE_BINARY_DATA_MODES=filesystem,s3
N8N_DEFAULT_BINARY_DATA_MODE=s3
# 主服务器使用 http://minio:9000；副服务器 worker 使用 http://li19dksfai11vm.bmwgroup.net:9000
N8N_EXTERNAL_STORAGE_S3_HOST=http://minio:9000
N8N_EXTERNAL_STORAGE_S3_PROTOCOL=http
N8N_EXTERNAL_STORAGE_S3_BUCKET_NAME=n8n-binary-data
N8N_EXTERNAL_STORAGE_S3_BUCKET_REGION=auto
N8N_EXTERNAL_STORAGE_S3_ACCESS_KEY=n8nminio
N8N_EXTERNAL_STORAGE_S3_ACCESS_SECRET=CHANGE_ME_MINIO_ROOT_PASSWORD
N8N_EXTERNAL_STORAGE_S3_FORCE_PATH_STYLE=true

# --- n8n 加密密钥 (MUST 主副服务器相同) ---------------------------------------
# 用 `openssl rand -hex 32` 生成 64 位十六进制密钥
N8N_ENCRYPTION_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# --- Task Runners (n8n 2.0+ Code 节点必需, MUST 主副服务器相同) ----------------
# 用 `openssl rand -hex 32` 生成
RUNNERS_AUTH_TOKEN=CHANGE_ME_RUNNER_AUTH_TOKEN

# --- Host / Protocol ---------------------------------------------------------
N8N_HOST=li19dksfai11vm.bmwgroup.net
N8N_PROTOCOL=https
WEBHOOK_URL=https://li19dksfai11vm.bmwgroup.net/
N8N_EDITOR_BASE_URL=https://li19dksfai11vm.bmwgroup.net/
N8N_PROXY_HOPS=1

# --- Worker ------------------------------------------------------------------
N8N_WORKER_CONCURRENCY=10

# --- Enterprise License -------------------------------------------------------
# 默认留空，部署后通过 UI Settings → License 激活，或在此填入激活码
N8N_LICENSE_ACTIVATION_KEY=

# --- 日志 --------------------------------------------------------------------
N8N_LOG_LEVEL=info   # debug | info | warn | error

# --- 时区 --------------------------------------------------------------------
GENERIC_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai
