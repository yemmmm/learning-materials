# =============================================================================
# n8n Enterprise HA - 环境变量
# =============================================================================
# 使用方法：
#   1. cp .env.example .env
#   2. 修改下方密码（初次部署建议运行 ./scripts/init.sh 自动生成强密码）
#   3. 如有 Enterprise License，填入 N8N_LICENSE_ACTIVATION_KEY
# =============================================================================

# --- n8n 加密密钥 -----------------------------------------------------------
# 必须在所有 main/worker 实例间共享，否则凭据无法跨节点解密
# 用 `openssl rand -hex 32` 生成
N8N_ENCRYPTION_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# --- Binary Data 存储 -------------------------------------------------------
# filesystem: 默认，无需 license（数据存到每个实例本地卷）
# s3:         存到 MinIO，需要 Enterprise license 激活后才能用
# 激活 license 后改为 s3 并 docker compose up -d --force-recreate
N8N_BINARY_DATA_MODE=filesystem

# --- Enterprise License -----------------------------------------------------
# 默认留空，部署后通过 UI Settings → License 激活，或在此填入激活码
N8N_LICENSE_ACTIVATION_KEY=

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=n8n_ha

# --- Redis ------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- MinIO ------------------------------------------------------------------
MINIO_ROOT_USER=n8n_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_STRONG_PASSWORD
MINIO_BUCKET_N8N=n8n-data

# --- Grafana ----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Logging ----------------------------------------------------------------
N8N_LOG_LEVEL=info   # debug | info | warn | error
